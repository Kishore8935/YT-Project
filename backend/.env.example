# Copy this file to ".env" and fill in real values. ".env" is gitignored.

# Postgres connection string (e.g. from Neon)
DATABASE_URL=

# Secret used to sign JWTs. Use a long random string.
JWT_SECRET=

# Cloudflare R2 credentials (S3-compatible API token with Object Read & Write)
R2_accessKey=
R2_secretKey=

# R2 bucket name
R2_bucket=

# Public base URL for the bucket (the pub-xxxx.r2.dev URL, no trailing slash)
R2_publicUrl=
